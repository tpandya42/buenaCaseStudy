# Supabase PostgreSQL connection string (Supabase dashboard → Project → Settings → Database → Connection string)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# Gemini AI API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY="your-gemini-api-key-here"

# Supabase JWT secret used to verify access tokens (Supabase dashboard → Project → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-here"
